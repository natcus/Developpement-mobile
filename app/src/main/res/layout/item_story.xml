<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="86dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:gravity="center"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp">

        <!-- L'image de profil / Story -->
        <ImageView
            android:id="@+id/imgStoryUser"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_story_ring"
            android:padding="3dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_myplaces" />

        <!-- Icône "+" pour ajouter une story (Visible seulement pour le premier item) -->
        <ImageView
            android:id="@+id/imgAddStoryIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/bg_add_story_icon"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/white"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/txtStoryUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="Nom"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/text_primary" />

</LinearLayout>
